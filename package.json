{
  "name": "rosetta-date-workspace",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "description": "Workspace root for rosetta-date — the library, its playground, and the docs site.",
  "author": "João Pedro Antunes Silva <hi@joaopedroas.com>",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm --filter rosetta-date build",
    "dev": "pnpm --filter rosetta-date dev",
    "test": "pnpm --filter rosetta-date test",
    "test:watch": "pnpm --filter rosetta-date test:watch",
    "test:coverage": "pnpm --filter rosetta-date test:coverage",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "playground": "pnpm --filter rosetta-date build && pnpm --filter @rosetta-date/playground dev",
    "playground:build": "pnpm --filter rosetta-date build && pnpm --filter @rosetta-date/playground build",
    "docs:dev": "pnpm --filter rosetta-date build && pnpm --filter @rosetta-date/docs dev",
    "docs:build": "pnpm --filter rosetta-date build && pnpm --filter @rosetta-date/docs build",
    "release": "pnpm --filter rosetta-date build && changeset publish"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@changesets/cli": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-markdown-preferences": "catalog:",
    "typescript": "catalog:"
  }
}
